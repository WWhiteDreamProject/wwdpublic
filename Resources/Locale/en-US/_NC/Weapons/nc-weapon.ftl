## Examine
nc-weapon-examine-brand = [color=cyan]Manufacturer:[/color] {$manufacturer} ({$tier})
nc-weapon-examine-durability = [color=cyan]Durability:[/color] [color={$color}]{$current}/{$max}[/color]
nc-weapon-examine-broken = [color=darkred][bold]BROKEN[/bold] — weapon cannot fire.[/color]
nc-weapon-examine-jammed = [color=red][bold]JAMMED[/bold] — cartridge extraction required.[/color]
