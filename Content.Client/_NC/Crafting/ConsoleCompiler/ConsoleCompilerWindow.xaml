<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client._NC.Crafting.ConsoleCompiler.ConsoleCompilerWindow"
               Title="{Loc 'console-compiler-window-title'}"
               SetWidth="640"
               SetHeight="480">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">

        <!-- ═══ Заголовок терминала ═══ -->
        <Label Text="{Loc 'console-compiler-window-title'}"
               FontColorOverride="#55EEFF"
               StyleClasses="LabelBig"
               HorizontalAlignment="Center"/>

        <BoxContainer Orientation="Horizontal" SeparationOverride="10" VerticalExpand="True">

            <!-- ══════════════════════════════════════════ -->
            <!-- ═══ ЛЕВАЯ ПАНЕЛЬ: DATA BANK / УТИЛИЗАЦИЯ ═══ -->
            <!-- ══════════════════════════════════════════ -->
            <PanelContainer HorizontalExpand="True" VerticalExpand="True" StyleClasses="Inset">
                <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="8">

                    <!-- Заголовок панели -->
                    <Label Text="{Loc 'console-compiler-window-data-bank-header'}"
                           FontColorOverride="#DDCC44"
                           Margin="0 0 0 4"/>

                    <!-- Инфо-блок: что вставлено -->
                    <PanelContainer StyleClasses="Inset" Margin="0 0 0 4">
                        <BoxContainer Orientation="Horizontal" Margin="8" SeparationOverride="10">
                            <!-- Иконка дискеты -->
                            <TextureRect Name="InputDiskIcon"
                                         TexturePath="/Textures/Objects/Misc/module.rsi/datadisk_base.png"
                                         SetWidth="32"
                                         SetHeight="32"
                                         VerticalAlignment="Center"/>

                            <BoxContainer Orientation="Vertical" VerticalAlignment="Center">
                                <Label Text="{Loc 'console-compiler-window-input-label'}" FontColorOverride="#55EEFF" StyleClasses="LabelSubText"/>
                                <Label Name="InputItemLabel"
                                       Text="{Loc 'console-compiler-window-input-empty'}"
                                       FontColorOverride="#55EEFF"
                                       StyleClasses="LabelHeading"/>
                            </BoxContainer>
                        </BoxContainer>
                    </PanelContainer>

                    <!-- Кнопка ОЦИФРОВАТЬ -->
                    <Button Name="DigitizeButton"
                            Text="{Loc 'console-compiler-window-digitize-button'}"
                            StyleClasses="Caution"
                            MinHeight="40"/>

                    <!-- Подсказки -->
                    <BoxContainer Orientation="Vertical" SeparationOverride="2">
                        <Label Text="{Loc 'console-compiler-window-digitize-hint-1'}" FontColorOverride="#AAAAAA" StyleClasses="LabelSubText"/>
                        <Label Text="{Loc 'console-compiler-window-digitize-hint-2'}" FontColorOverride="#AAAAAA" StyleClasses="LabelSubText"/>
                    </BoxContainer>

                    <Control VerticalExpand="True"/>

                    <!-- Блок памяти -->
                    <PanelContainer StyleClasses="Inset">
                        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="2">
                            <Label Text="{Loc 'console-compiler-window-memory-label'}" FontColorOverride="#55EEFF" HorizontalAlignment="Center"/>
                            <Label Name="AvailableDataLabel"
                                   Text="0 MB"
                                   FontColorOverride="#DDCC44"
                                   StyleClasses="LabelBig"
                                   HorizontalAlignment="Center"/>
                        </BoxContainer>
                    </PanelContainer>

                    <!-- Кнопка ИЗВЛЕЧЬ -->
                    <Button Name="EjectReceiverButton" Text="{Loc 'console-compiler-window-eject-button'}"/>

                </BoxContainer>
            </PanelContainer>

            <!-- ══════════════════════════════════════════ -->
            <!-- ═══ ПРАВАЯ ПАНЕЛЬ: COMPILER / ПЕЧАТЬ ═══ -->
            <!-- ══════════════════════════════════════════ -->
            <PanelContainer HorizontalExpand="True" VerticalExpand="True" StyleClasses="Inset">
                <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="8">

                    <!-- Заголовок панели -->
                    <Label Text="{Loc 'console-compiler-window-compiler-header'}"
                           FontColorOverride="#DDCC44"
                           Margin="0 0 0 4"/>

                    <!-- Инфо-блок: загруженная технология -->
                    <PanelContainer StyleClasses="Inset" Margin="0 0 0 4">
                        <BoxContainer Orientation="Horizontal" Margin="8" SeparationOverride="10">
                            <!-- Иконка мастер-диска -->
                            <TextureRect Name="MasterDiskIcon"
                                         TexturePath="/Textures/Objects/Misc/module.rsi/datadisk_base.png"
                                         SetWidth="32"
                                         SetHeight="32"
                                         VerticalAlignment="Center"/>

                            <BoxContainer Orientation="Vertical" VerticalAlignment="Center">
                                <Label Text="{Loc 'console-compiler-window-loaded-label'}" FontColorOverride="#DDCC44" StyleClasses="LabelSubText"/>
                                <Label Name="MasterDiskLabel"
                                       Text="{Loc 'console-compiler-window-matrix-not-found'}"
                                       FontColorOverride="#DDCC44"
                                       StyleClasses="LabelHeading"/>
                            </BoxContainer>
                        </BoxContainer>
                    </PanelContainer>

                    <!-- Статус матрицы -->
                    <Label Name="MatrixStatusLabel"
                           Text="STATUS: [UNKNOWN]"
                           FontColorOverride="#AAAAAA"
                           StyleClasses="LabelSubText"/>

                    <!-- Остаток использований -->
                    <BoxContainer Orientation="Vertical" SeparationOverride="0">
                        <Label Text="{Loc 'console-compiler-window-uses-label'}" FontColorOverride="#AAAAAA" StyleClasses="LabelSubText"/>
                        <Label Name="UsesLeftLabel"
                               Text="[ — ]"
                               FontColorOverride="#DDCC44"
                               StyleClasses="LabelHeading"/>
                    </BoxContainer>

                    <Control VerticalExpand="True"/>

                    <!-- Кнопка ПЕЧАТЬ ЧЕРТЕЖ -->
                    <BoxContainer Orientation="Vertical" SeparationOverride="2">
                        <Button Name="PrintBlueprintButton"
                                Text="{Loc 'console-compiler-window-print-blueprint'}"
                                StyleClasses="Caution"
                                MinHeight="36"/>
                        <Label Name="BlueprintCostLabel"
                               Text="COST: 0 MB | DRAIN: 0 USES"
                               FontColorOverride="#AAAAAA"
                               StyleClasses="LabelSubText"
                               HorizontalAlignment="Center"/>
                    </BoxContainer>

                    <!-- Кнопка ПЕЧАТЬ РЕЦЕПТ -->
                    <BoxContainer Orientation="Vertical" SeparationOverride="2">
                        <Button Name="PrintRecipeButton"
                                Text="{Loc 'console-compiler-window-print-recipe'}"
                                StyleClasses="Caution"
                                MinHeight="36"/>
                        <Label Name="RecipeCostLabel"
                               Text="COST: 0 MB | DRAIN: 0 USES"
                               FontColorOverride="#AAAAAA"
                               StyleClasses="LabelSubText"
                               HorizontalAlignment="Center"/>
                    </BoxContainer>

                    <!-- Кнопка ИЗВЛЕЧЬ ДИСК -->
                    <Button Name="EjectMasterButton" Text="{Loc 'console-compiler-window-eject-master-button'}"/>

                </BoxContainer>
            </PanelContainer>

        </BoxContainer>

        <!-- ═══ Статусная строка ═══ -->
        <Label Name="StatusLabel" Text="" FontColorOverride="#666666" StyleClasses="LabelSubText"/>

    </BoxContainer>
</DefaultWindow>
