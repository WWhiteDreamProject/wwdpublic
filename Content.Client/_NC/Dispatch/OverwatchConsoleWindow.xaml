<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      x:Class="Content.Client._NC.Dispatch.OverwatchConsoleWindow"
                      Title="Overwatch Dispatch"
                      MinSize="600 400"
                      SetSize="800 500">
    <PanelContainer>
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#050d12" BorderColor="#14606E" BorderThickness="2"/>
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Vertical" Margin="10">
            <!-- Header -->
            <PanelContainer MinHeight="45" Margin="0 0 0 10">
                 <PanelContainer.PanelOverride>
                     <gfx:StyleBoxFlat BackgroundColor="#0a2a2f" BorderColor="#FF5252" BorderThickness="2"/>
                 </PanelContainer.PanelOverride>
                 <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                     <Label Text="Око Сити - Overwatch Dispatch" FontColorOverride="#FF5252" StyleClasses="LabelBig" Margin="5"/>
                 </BoxContainer>
            </PanelContainer>

            <!-- Alert headers -->
            <PanelContainer MinHeight="30" Margin="0 0 0 5">
                <BoxContainer Orientation="Horizontal" Margin="5 0">
                    <Label Text="[TIME]" MinWidth="60" FontColorOverride="#FF5252" StyleClasses="LabelHeading"/>
                    <Control MinSize="10 0"/>
                    <Label Text="[TYPE]" MinWidth="80" FontColorOverride="#FF5252" StyleClasses="LabelHeading"/>
                    <Control MinSize="10 0"/>
                    <Label Text="[SECTOR]" HorizontalExpand="True" FontColorOverride="#FF5252" StyleClasses="LabelHeading"/>
                    <Control MinSize="10 0"/>
                    <Label Text="[CAMERA]" MinWidth="120" FontColorOverride="#FF5252" StyleClasses="LabelHeading"/>
                    <Control MinSize="10 0"/>
                    <Label Text="[ACTIONS]" MinWidth="200" FontColorOverride="#FF5252" StyleClasses="LabelHeading" Align="Center"/>
                </BoxContainer>
            </PanelContainer>

            <!-- Alerts list -->
            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#091316" BorderColor="#14606E" BorderThickness="1"/>
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" Margin="2">
                    <BoxContainer Name="AlertList" Orientation="Vertical" SeparationOverride="2"/>
                </ScrollContainer>
            </PanelContainer>
        </BoxContainer>
    </PanelContainer>
</controls:FancyWindow>