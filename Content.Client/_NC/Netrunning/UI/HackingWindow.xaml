<DefaultWindow xmlns="https://spacestation14.io"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NET SPACE INTERFACE"
        SetSize="600 550"
        MinSize="600 550"
        Resizable="False">
    <BoxContainer Orientation="Vertical" Margin="10">
        <!-- Header: Target Info -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="10" Margin="0 0 0 10">
            <Label Text="TARGET SERVER:" FontColorOverride="#00FF00" />
            <Label Name="TargetName" Text="Unknown" />
            <Control HorizontalExpand="True" />
            <Label Text="ТАЙМЕР:" FontColorOverride="#FF5500"/>
            <Label Name="TimerLabel" Text="10" FontColorOverride="#FF5500"/>
            <Label Text="FLOOR:" FontColorOverride="#FFFF00" Margin="20 0 0 0"/>
            <Label Name="FloorLabel" Text="1" />
        </BoxContainer>

        <!-- Main Display: ICE Status -->
        <PanelContainer VerticalExpand="True" StyleClasses="LowDivider">
            <BoxContainer Orientation="Vertical" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Name="IceTypeLabel" Text="GATE ЛЁД ОБНАРУЖЕН" Align="Center" FontColorOverride="#FF0000" StyleClasses="LabelHeading"/>

                <ProgressBar Name="IceHealthBar" MinHeight="20" MinWidth="200" Margin="0 10 0 0">
                    <Label Name="IceHealthLabel" Text="20/20" Align="Center" StyleClasses="LabelSmall" />
                </ProgressBar>

                <Label Name="StatusLog" Text="Connection Established..." Align="Center" FontColorOverride="Gray" Margin="0 10 0 0"/>
            </BoxContainer>
        </PanelContainer>

        <!-- Player Stats -->
        <BoxContainer Orientation="Horizontal" Margin="0 10 0 5">
            <Label Text="RAM INTEGRITY:" FontColorOverride="#00FFFF"/>
            <ProgressBar Name="PlayerRamBar" HorizontalExpand="True" MinHeight="15" Margin="5 0 0 0">
                <Label Name="PlayerRamLabel" Text="10/10" Align="Center" StyleClasses="LabelSmall"/>
            </ProgressBar>
        </BoxContainer>

        <!-- Programs (Combat) -->
        <Label Text="AVAILABLE PROGRAMS:" FontColorOverride="Gray" Margin="0 5 0 2"/>
        <GridContainer Name="ProgramGrid" Columns="4" HorizontalExpand="True" VerticalExpand="True" MinHeight="80"/>

        <!-- Password (Gate) -->
        <BoxContainer Name="PasswordContainer" Orientation="Horizontal" Margin="0 10 0 0" Visible="False">
            <Label Text="PASSPHRASE REQUIREMENT:" VerticalAlignment="Center" FontColorOverride="#FFAA00"/>
            <LineEdit Name="PasswordInput" HorizontalExpand="True" PlaceHolder="Enter 4-digit PIN"/>
            <Button Name="SubmitPasswordButton" Text="EXECUTE" />
        </BoxContainer>

    </BoxContainer>
</DefaultWindow>
