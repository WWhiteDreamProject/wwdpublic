<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:controls="clr-namespace:Robust.Client.UserInterface.Controls;assembly=Robust.Client"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Class="Content.Client._NC.Netrunning.UI.CyberdeckWindow"
               Title="Cyberdeck"
               MinSize="300 150">
    <BoxContainer Orientation="Vertical" Margin="5">
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 5">
            <Label Text="RAM:" Margin="0 0 5 0"/>
            <ProgressBar Name="RamBar" MinValue="0" MaxValue="10" HorizontalExpand="True" MinHeight="20"/>
        </BoxContainer>
        <Label Name="RamText" Text="0/10" HorizontalAlignment="Center"/>

        <Label Text="Current Target: None" Name="TargetLabel" FontColorOverride="Red" Margin="0 10 0 0"/>

        <Label Text="Installed Programs:" FontColorOverride="Gray" Margin="0 10 0 0"/>
        <GridContainer Name="ProgramList" Columns="3" HorizontalExpand="True" VerticalExpand="True"/>

        <Label Text="Nearby Networks:" FontColorOverride="Gray" Margin="0 10 0 0"/>

        <BoxContainer Name="DeviceList" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" MinHeight="100"/>
    </BoxContainer>
</DefaultWindow>
