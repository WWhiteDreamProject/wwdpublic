<controls:FancyWindow xmlns="https://spacestation14.io"
                     xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                     xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     x:Class="Content.Client._NC.Cyberware.UI.CyberwareAutodocWindow"
                     Title="AUTODOC TERMINAL — R.A.V. v1.5"
                     MinSize="1050 600"
                     SetSize="1100 650">

    <!-- Основной фоновый контейнер в стиле киберпанк-терминала -->
    <PanelContainer HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#080c08" BorderColor="#1a3a1a" BorderThickness="2"/>
        </PanelContainer.PanelOverride>

        <BoxContainer Orientation="Vertical" Margin="10" HorizontalExpand="True" VerticalExpand="True">

            <!-- ═══════════ HEADER: Данные пациента ═══════════ -->
            <PanelContainer Margin="0 0 0 8">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#0c180c" BorderColor="#2a5a2a" BorderThickness="1"/>
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" Margin="10 6" SeparationOverride="8">
                    <Label Text="TRAUMA TEAM — R.A.V. v1.5" FontColorOverride="#ffaa00" StyleClasses="LabelHeading"/>
                    <Control HorizontalExpand="True"/>
                    <Label Text="Пациент:" FontColorOverride="#557755"/>
                    <Label Name="PatientNameLabel" Text="[НЕТ ДАННЫХ]" FontColorOverride="#00ff88"/>
                    <Control MinWidth="20"/>
                    <Label Text="Статус:" FontColorOverride="#557755"/>
                    <Label Name="PatientStatusLabel" Text="—" FontColorOverride="#ffaa00"/>
                </BoxContainer>
            </PanelContainer>

            <!-- ═══════════ MAIN: Три колонки (слоты — персонаж — слоты) ═══════════ -->
            <BoxContainer Orientation="Horizontal" VerticalExpand="True" HorizontalExpand="True" SeparationOverride="8">

                <!-- ЛЕВАЯ КОЛОНКА: слоты головы и левой стороны -->
                <BoxContainer Name="LeftSlotsContainer" Orientation="Vertical" MinWidth="260"
                              SeparationOverride="4" VerticalExpand="True"/>

                <!-- ЦЕНТРАЛЬНАЯ КОЛОНКА: спрайт пациента из Автодока -->
                <PanelContainer HorizontalExpand="True" VerticalExpand="True">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#060a06" BorderColor="#1a3a1a" BorderThickness="1"/>
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
                        <Control VerticalExpand="True"/>
                        <!-- SpriteView отрисовывает персонажа, лежащего в автодоке -->
                        <SpriteView Name="PatientSprite" Scale="5 5" OverrideDirection="South"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Control VerticalExpand="True"/>
                        <Label Name="PatientSpriteLabel" Text="[ПАЦИЕНТ НЕ ОБНАРУЖЕН]"
                               FontColorOverride="#556655" HorizontalAlignment="Center" Margin="0 0 0 8"/>
                    </BoxContainer>
                </PanelContainer>

                <!-- ПРАВАЯ КОЛОНКА: слоты конечностей и внешних имплантов -->
                <BoxContainer Name="RightSlotsContainer" Orientation="Vertical" MinWidth="260"
                              SeparationOverride="4" VerticalExpand="True"/>

            </BoxContainer>

            <!-- ═══════════ FOOTER: статус системы ═══════════ -->
            <PanelContainer Margin="0 8 0 0">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#0c180c" BorderColor="#2a5a2a" BorderThickness="1"/>
                </PanelContainer.PanelOverride>
                <Label Text="[ СИСТЕМА АВТОДОКА АКТИВНА ]" FontColorOverride="#557755"
                       HorizontalAlignment="Center" Margin="0 6"/>
            </PanelContainer>

        </BoxContainer>
    </PanelContainer>
</controls:FancyWindow>